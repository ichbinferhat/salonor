generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  OWNER
  ADMIN
}

enum AppointmentStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  phone        String?
  passwordHash String
  role         Role          @default(CUSTOMER)
  image        String?
  createdAt    DateTime      @default(now())
  business     Business?
  appointments Appointment[]
  reviews      Review[]
  favorites    Favorite[]
  devices      DeviceToken[]
}

// Mobil uygulama (Expo) push bildirimi cihaz jetonları. Bir kullanıcının birden çok
// cihazı olabilir; jeton benzersizdir (aynı cihaz tekrar kaydolursa upsert ile güncellenir).
model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique // Expo push token: "ExponentPushToken[...]"
  platform  String   @default("unknown") // "ios" | "android"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Category {
  id         String     @id @default(cuid())
  slug       String     @unique
  name       String
  emoji      String
  image      String
  businesses Business[]
}

model Business {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  phone       String
  whatsappPhone String? // İsteğe bağlı WhatsApp hattı; boşsa salon sayfasında `phone` kullanılır
  address     String
  district    String
  city        String
  lat         Float
  lng         Float
  googlePlaceId String? // Google "yorum yaz" derin bağlantısı için (writereview?placeid=)
  promoText   String?  // salon sayfasında öne çıkan kampanya/duyuru (ör. "Bu hafta saç boyamada %20 indirim")
  promoUntil  String?  // YYYY-MM-DD; bu tarihe kadar gösterilir (boş = süresiz)
  coverImage  String
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  plan        String   @default("baslangic") // baslangic | profesyonel | kurumsal
  planStartedAt DateTime? // abonelik/paket başlangıcı (elden tahsilatta admin ayarlar)
  planExpiresAt DateTime? // abonelik bitiş tarihi; geçince panelde uyarı gösterilir (otomatik tahsilat YOK — Ferhat elden alıyor)
  smsCredits  Int      @default(0)
  ratingAvg   Float    @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())

  ownerId    String @unique
  owner      User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images            BusinessImage[]
  hours             WorkingHour[]
  staff             Staff[]
  serviceCategories ServiceCategory[]
  services          Service[]
  appointments      Appointment[]
  reviews           Review[]
  favorites         Favorite[]
  expenses          Expense[]
  packages          Package[]
  campaigns         Campaign[]
  products          Product[]
  sales             Sale[]
  giftCards         GiftCard[]
  loyaltyAccounts   LoyaltyAccount[]
  debts             Debt[]
  smsLogs           SmsLog[]
  todos             TodoTask[]

  @@index([city])
  @@index([categoryId])
}

model BusinessImage {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  url        String
  sort       Int      @default(0)
}

model WorkingHour {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  weekday    Int
  openMin    Int
  closeMin   Int
  closed     Boolean  @default(false)

  @@unique([businessId, weekday])
}

model ServiceCategory {
  id         String    @id @default(cuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  sort       Int       @default(0)
  services   Service[]
}

model Service {
  id          String            @id @default(cuid())
  businessId  String
  business    Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  categoryId  String
  category    ServiceCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  durationMin Int
  priceTl     Int
  sort        Int               @default(0)
  staff       StaffService[]
  items       AppointmentItem[]
}

model Staff {
  id            String         @id @default(cuid())
  businessId    String
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name          String
  title         String
  image         String
  active        Boolean        @default(true)
  commissionPct Int            @default(0)
  services      StaffService[]
  appointments  Appointment[]
}

model StaffService {
  staffId   String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
}

model Appointment {
  id           String            @id @default(cuid())
  code         String            @unique
  businessId   String
  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId   String?
  customer     User?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName String?
  customerPhone String?
  staffId      String
  staff        Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date         String
  startMin     Int
  endMin       Int
  status       AppointmentStatus @default(CONFIRMED)
  totalTl      Int
  note         String?
  reminderSentAt DateTime?       // ertesi-gün hatırlatması gönderildiyse işaretlenir (çift gönderimi önler)
  reminder3hSentAt DateTime?     // randevudan ~3 saat önce hatırlatma gönderildiyse işaretlenir (ayrı kanal)
  seenAt       DateTime?         // işletme sahibi yeni randevuyu gördü/onayladıysa işaretlenir (bildirim sayacı)
  createdAt    DateTime          @default(now())
  items        AppointmentItem[]
  review       Review?

  @@index([businessId, date])
  @@index([staffId, date])
  @@index([customerId])
  // ÇİFT REZERVASYON KORUMASI: aşağıdaki kısmi (partial) unique index DB seviyesinde
  // canlıdır ve aynı personele aynı tarih+saatte ikinci aktif randevu yazılmasını engeller.
  // Prisma şeması "partial unique index" ifade edemediği için raw SQL ile kurulur:
  //   CREATE UNIQUE INDEX appt_no_double_book ON "Appointment" ("staffId", date, "startMin")
  //     WHERE status IN ('CONFIRMED','COMPLETED');
  // Yeniden kurmak için: `npx tsx prisma/ensure-indexes.ts`. `prisma db push` sonrası
  // bu indeks düşerse mutlaka tekrar çalıştır — booking.ts atomik kontrolünün DB güvencesidir.
}

model AppointmentItem {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String?
  service       Service?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  name          String
  durationMin   Int
  priceTl       Int
}

model Review {
  id            String       @id @default(cuid())
  businessId    String
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      User?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  authorName    String?      // girişsiz (anonim) yorumlarda görünen ad
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  rating        Int
  comment       String
  reply         String?
  verified      Boolean      @default(false) // tamamlanmış randevusu olan girişli müşteriden → "Doğrulanmış randevu" rozeti + anında yayında
  hidden        Boolean      @default(false) // admin gizledi VEYA doğrulanmamış yorum onay bekliyor → vitrinde görünmez + puana sayılmaz
  reported      Boolean      @default(false) // işletme sahibi şikayet etti → admin incelesin
  createdAt     DateTime     @default(now())

  @@index([businessId, createdAt])
}

model Favorite {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([userId, businessId])
}

model Expense {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title      String
  category   String   @default("Diğer")
  amountTl   Int
  date       String // YYYY-MM-DD (Europe/Istanbul)
  note       String?
  createdAt  DateTime @default(now())

  @@index([businessId, date])
}

model Package {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  priceTl      Int
  sessions     Int      @default(1)
  validityDays Int      @default(30)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([businessId])
}

model Campaign {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  code        String
  description String?
  discountPct Int
  active      Boolean  @default(true)
  expiresAt   String? // YYYY-MM-DD
  usedCount   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([businessId])
}

model Product {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  priceTl    Int
  stock      Int      @default(0)
  lowStockAt Int      @default(5)
  createdAt  DateTime @default(now())

  @@index([businessId])
}

model Sale {
  id            String     @id @default(cuid())
  businessId    String
  business      Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName  String?
  totalTl       Int
  paymentMethod String     @default("Nakit")
  date          String // YYYY-MM-DD (Europe/Istanbul)
  createdAt     DateTime   @default(now())
  items         SaleItem[]

  @@index([businessId, date])
}

model SaleItem {
  id      String @id @default(cuid())
  saleId  String
  sale    Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  name    String
  kind    String @default("product") // service | product | other
  qty     Int    @default(1)
  priceTl Int
}

// Hediye Çeki Sistemi
model GiftCard {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  code       String   @unique
  amountTl   Int // başlangıç tutarı
  balanceTl  Int // kalan bakiye
  buyerName  String?
  recipient  String? // alıcı / not
  active     Boolean  @default(true)
  expiresAt  String? // YYYY-MM-DD
  createdAt  DateTime @default(now())

  @@index([businessId])
}

// Para Puan (Sadakat) Sistemi — müşteri telefonuna göre
model LoyaltyAccount {
  id           String       @id @default(cuid())
  businessId   String
  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName String
  phone        String
  points       Int          @default(0)
  createdAt    DateTime     @default(now())
  txns         LoyaltyTxn[]

  @@unique([businessId, phone])
  @@index([businessId])
}

model LoyaltyTxn {
  id        String         @id @default(cuid())
  accountId String
  account   LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  delta     Int // + kazanım / - harcama
  reason    String
  createdAt DateTime       @default(now())

  @@index([accountId])
}

// Borç / Taksitli Satış Takibi
model Debt {
  id           String        @id @default(cuid())
  businessId   String
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName String
  phone        String?
  totalTl      Int
  paidTl       Int           @default(0)
  installments Int           @default(1)
  note         String?
  date         String // YYYY-MM-DD
  createdAt    DateTime      @default(now())
  payments     DebtPayment[]

  @@index([businessId])
}

model DebtPayment {
  id        String   @id @default(cuid())
  debtId    String
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  amountTl  Int
  method    String   @default("Nakit")
  date      String // YYYY-MM-DD
  createdAt DateTime @default(now())

  @@index([debtId])
}

// İşletme iş birliği talepleri (/iletisim formundan gelir, admin panelinde görünür)
model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  handled   Boolean  @default(false) // admin işledi/iletişime geçti mi
  createdAt DateTime @default(now())

  @@index([handled, createdAt])
}

// Yapılacaklar Listesi — işletmeye özel görev/hatırlatma takibi
model TodoTask {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title       String
  done        Boolean   @default(false)
  priority    String    @default("normal") // dusuk | normal | yuksek
  dueDate     String? // YYYY-MM-DD (Europe/Istanbul)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([businessId, done])
}

// SMS gönderim kayıtları (kontör düşümü + geçmiş)
model SmsLog {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  toPhone    String
  body       String
  kind       String   @default("manual") // manual | confirm | reminder | bulk
  status     String   @default("queued") // queued | sent | failed | mock
  credits    Int      @default(1)
  createdAt  DateTime @default(now())

  @@index([businessId, createdAt])
}
